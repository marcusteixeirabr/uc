# Renomeie este arquivo para .env e preencha com suas credenciais do Supabase.
#
# Como obter:
#   DATABASE_URL → Supabase → Settings → API → Project URL
#   DATABASE_KEY → Supabase → Settings → API → anon / public
#   GOOSE_DBSTRING → Supabase → Settings → Database → Connection string → URI
#
# ATENÇÃO: nunca compartilhe o arquivo .env com as credenciais reais.

# Usado pelo app em runtime (PostgREST via HTTPS)
DATABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
DATABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Usado pelo goose para migrations (conexão PostgreSQL direta)
GOOSE_DBSTRING=postgresql://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

PORT=8180
